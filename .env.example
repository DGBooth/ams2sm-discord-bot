# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_token_here

# Base URL of your AMS2 Server Manager instance (no trailing slash)
AMS2SM_BASE_URL=

# Direct URL of the AMS2 game server's built-in HTTP API (optional, no trailing slash)
# Enables /session and automatic track name resolution
# Typically http://<server-ip>:9000
AMS2_GAME_SERVER_URL=
